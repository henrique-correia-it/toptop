# Páginas de erro personalizadas
ErrorDocument 404 /404.php

# --- BLOQUEIO DE FICHEIROS E DIRETÓRIOS SENSÍVEIS ---

<Files ".env">
    Require all denied
</Files>

<FilesMatch "^\.">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule (^|/)\.(?!well-known) - [F,L]
</IfModule>

# Bloqueia acesso direto a logs
<Files "error_log">
    Require all denied
</Files>
<Files "webhook_debug.log">
    Require all denied
</Files>
<FilesMatch "\.(log|ini|bak|sql|sh|bat)$">
    Require all denied
</FilesMatch>

# Bloqueia ficheiros de documentação e configuração do projecto
<FilesMatch "^(CLAUDE|README|CHANGELOG|composer\.json|composer\.lock|package\.json|package-lock\.json)">
    Require all denied
</FilesMatch>

# Bloqueia acesso direto a ficheiros PHP de configuração e includes sensíveis
<IfModule mod_rewrite.c>
    RewriteRule ^config/.*\.php$ - [F,L]
    RewriteRule ^admin/includes/.*\.php$ - [F,L]
    RewriteRule ^admin/config/.*$ - [F,L]
    RewriteRule ^logs/ - [F,L]
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # REGRA 1: Forçar HTTPS apenas no servidor online (não em localhost)
    RewriteCond %{REQUEST_METHOD} !POST [NC]
    RewriteCond %{HTTP_HOST} !^localhost$ [NC]
    RewriteCond %{HTTP_HOST} !^127\.0\.0\.1$ [NC]
    RewriteCond %{HTTP:X-Forwarded-Proto} !https
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP:CF-Visitor} !{"scheme":"https"}
    RewriteRule (.*) https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Regras para os painéis e login (limpam a URL)
    RewriteRule ^dev/?$ dev/dev.php [L]
    RewriteRule ^admin/?$ admin/admin.php [L]
    RewriteRule ^login/?$ /entrar [R=301,L]

    # Area de cliente
    RewriteRule ^entrar/?$ entrar.php [L]
    RewriteRule ^registar/?$ registar.php [L]
    RewriteRule ^sair/?$ sair.php [L]
    RewriteRule ^recuperar-conta/?$ recuperar-conta.php [L]
    RewriteRule ^admin/recuperar_senha\.php$ /recuperar-conta [R=301,L]
    RewriteRule ^redefinir-conta/?$ redefinir-conta.php [L]
    RewriteRule ^admin/reset_senha\.php$ /redefinir-conta [R=301,L]
    RewriteRule ^minha-conta/?$ minha-conta.php [L]
    RewriteRule ^minha-conta/encomendas/?$ minha-conta-encomendas.php [L]
    RewriteRule ^minha-conta/encomenda/?$ minha-conta-encomenda.php [L]
    RewriteRule ^minha-conta/moradas/?$ minha-conta-moradas.php [L]
    RewriteRule ^minha-conta/dados/?$ minha-conta-dados.php [L]

    # Regra para URLs amigáveis de produtos (existente)
    RewriteRule ^produto/([a-zA-Z0-9-]+)$ produto.php?slug=$1 [L]

    # Evita redirecionar POST para preservar dados do formulário (existente)
    RewriteCond %{REQUEST_METHOD} !POST
    RewriteCond %{THE_REQUEST} /([^.]+)\.php [NC]
    RewriteRule ^ /%1 [R=301,L]

    # Quando não for arquivo ou pasta, adiciona .php internamente (existente)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^([^.]+)$ $1.php [L]
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  
  # Imagens (Podem ficar em cache)
  ExpiresByType image/jpg "access 1 year"
  ExpiresByType image/jpeg "access 1 year"
  ExpiresByType image/gif "access 1 year"
  ExpiresByType image/png "access 1 year"
  ExpiresByType image/webp "access 1 year"
  ExpiresByType image/avif "access 1 year"
  ExpiresByType text/css "access 1 month"
  ExpiresByType application/javascript "access 1 month"
  
  # HTML e PHP (NUNCA guardar em cache)
  ExpiresByType text/html "access 0 seconds"
  ExpiresByType application/json "access 0 seconds"
  
  ExpiresDefault "access 0 seconds"
</IfModule>


<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/x-javascript
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/xml
</IfModule>

# --- CABEÇALHOS DE SEGURANÇA CORRIGIDOS ---
<IfModule mod_headers.c>
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"

  # --- CSP CORRIGIDA ---
  # Adicionámos https://www.google.com à diretiva 'frame-src' para permitir o mapa.
  Header set Content-Security-Policy "default-src 'self'; connect-src 'self' https://unpkg.com https://api.stripe.com; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://unpkg.com https://cdnjs.cloudflare.com https://js.stripe.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://*.stripe.com; frame-src 'self' https://www.google.com https://js.stripe.com;"
</IfModule>
